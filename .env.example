# Application
APP_ENV=development
HTTP_PORT=8080
LOG_LEVEL=INFO
STORAGE_DRIVER=postgres

# Authentication
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_MINUTES=10080

# Database
DB_HOST=db
DB_PORT=5432
DB_NAME=blog
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSLMODE=disable
POSTGRES_DB=blog
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# OpenTelemetry
OTEL_ENABLED=false
OTEL_SERVICE_NAME=blog-api
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_EXPORTER_OTLP_TIMEOUT_SECONDS=5
OTEL_EXPORTER_OTLP_CERT_FILE=
OTEL_EXPORTER_OTLP_SERVER_NAME=

# HTTP server
HTTP_READ_TIMEOUT_SECONDS=10
HTTP_WRITE_TIMEOUT_SECONDS=10
HTTP_SHUTDOWN_TIMEOUT_SECONDS=10
